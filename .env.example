# 🚀 PulsorClip Environment Configuration
# Use this file as a template for your local .env file.
# Each variable is documented with its purpose and default behavior.

# ------------------------------------------------------------------------------
# 🌐 CORE APPLICATION SETTINGS
# ------------------------------------------------------------------------------

# The base URL of the web application. Used for generating links in Telegram.
# Default: http://localhost:10000
NEXT_PUBLIC_APP_URL=https://your-pulsorclip-domain.com

# Port the web server listens on.
# Default: 10000
PORT=10000

# The human-readable name of the application.
APP_NAME=PulsorClip

# Default language for the bot and reports (values: "en", "fr").
# Default: en
PULSORCLIP_DEFAULT_LOCALE=en

# ------------------------------------------------------------------------------
# 🤖 TELEGRAM BOT SETTINGS
# ------------------------------------------------------------------------------

# Telegram Bot API Token from @BotFather. REQUIRED for bot functionality.
TELEGRAM_BOT_TOKEN=8685051066:AA...

# The public @username of your bot (without the @).
TELEGRAM_BOT_USERNAME=pulsorclip_bot

# Global toggle to enable/disable the Telegram bot interface.
# Default: true
TELEGRAM_BOT_ENABLED=true

# Maximum file size (in MB) for direct Telegram uploads. 
# Note: Telegram Bot API has a hard limit of 50MB for uploads.
# Default: 45
TELEGRAM_UPLOAD_LIMIT_MB=45

# Enable to restrict bot usage to an allowlist (requires additional setup).
# Default: false
TELEGRAM_BOT_ALLOW_USERS=false

# ------------------------------------------------------------------------------
# 🛡️ ADMINISTRATIVE SETTINGS
# ------------------------------------------------------------------------------

# Comma-separated list of Telegram User IDs with admin privileges.
# Admins receive health reports, startup alerts, and can use maintenance commands.
TELEGRAM_ADMIN_IDS=12345678,98765432

# The @username of the administrator contact for /support (without the @).
# Default: admin
TELEGRAM_ADMIN_HANDLE=your_handle

# Enable maintenance mode to block non-admins and show a maintenance message.
# Default: false
TELEGRAM_MAINTENANCE_MODE=false

# ------------------------------------------------------------------------------
# 📊 MONITORING & REPORTS
# ------------------------------------------------------------------------------

# Enable automated daily statistics reports sent to admins.
# Default: true
PULSORCLIP_DAILY_REPORT_ENABLED=true

# The UTC hour (0-23) when the daily report should be sent.
# Default: 0
PULSORCLIP_DAILY_REPORT_HOUR=0

# Frequency (in minutes) for internal system health checks.
# Default: 15
PULSORCLIP_HEALTH_CHECK_CADENCE_MINS=15

# ------------------------------------------------------------------------------
# ⚙️ SYSTEM & BINARIES
# ------------------------------------------------------------------------------

# Directory for temporary storage of processed media files.
# Default: downloads
PULSORCLIP_DOWNLOAD_DIR=./downloads

# Path to the yt-dlp binary. If left empty, the system will try auto-discovery.
YTDLP_BIN=

# Path to the ffmpeg binary. If left empty, the system will try auto-discovery.
FFMPEG_BIN=

# Number of CPU threads ffmpeg is allowed to use. 
# Recommended: 2 for small VPS instances to avoid OOM.
# Default: 2
FFMPEG_THREADS=2

# ------------------------------------------------------------------------------
# 🐞 DEBUGGING & LOGS
# ------------------------------------------------------------------------------

# Enable verbose logging for debugging extraction or startup issues.
# Default: false
PULSORCLIP_DEBUG_LOGS=false

# If true, logs will include full URLs (may contain sensitive tokens).
# Default: false
PULSORCLIP_LOG_FULL_URLS=false

# ------------------------------------------------------------------------------
# 🍪 YT-DLP AUTHENTICATION (COOKIES)
# ------------------------------------------------------------------------------
# Use these settings if YouTube or other sites block access with "Sign in to confirm".
# Only ONE of these options should be used at a time.

# Option 1: Path to a Netscape formatted cookies.txt file.
YTDLP_COOKIES_FILE=

# Option 2: Base64-encoded content of a cookies.txt file (useful for PaaS like Railway).
YTDLP_COOKIES_BASE64=

# Option 3: Extract cookies directly from a local browser (e.g., "chrome", "firefox").
# Note: This usually only works on local dev machines, not in Docker/Cloud.
YTDLP_COOKIES_FROM_BROWSER=