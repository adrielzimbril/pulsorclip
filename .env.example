# PulsorClip local environment
# This file documents every supported variable.
# Copy values into your local `.env`.

# Public web URL used for metadata and Telegram links.
NEXT_PUBLIC_APP_URL=https://your-domain.example.com
PORT=10000

# Optional server logging.
# Enable debug logs when diagnosing extractor failures or startup issues.
PULSORCLIP_DEBUG_LOGS=false

# When true, logs keep full source URLs instead of redacted origin/path only.
# Keep this false unless you explicitly want full URLs in logs.
PULSORCLIP_LOG_FULL_URLS=false

# Downloader binaries on the host machine or inside Docker.
YTDLP_BIN=yt-dlp
FFMPEG_BIN=ffmpeg

# PulsorClip Cron Check Config
PULSORCLIP_DAILY_REPORT_HOUR=0
PULSORCLIP_HEALTH_CHECK_CADENCE_MINS=15

# Downloads directory.
# Locally this can stay relative to the repository root.
PULSORCLIP_DOWNLOAD_DIR=./downloads

# UI locale fallback when there is no cookie and no useful Accept-Language header.
PULSORCLIP_DEFAULT_LOCALE=en

# Telegram bot runtime.
TELEGRAM_BOT_ENABLED=true
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=pulsorclip_bot
TELEGRAM_UPLOAD_LIMIT_MB=45
TELEGRAM_BOT_ALLOW_USERS=false

# Comma-separated Telegram user IDs that should receive startup notifications.
# Important: each admin must have already opened a private chat with the bot,
# otherwise Telegram can reject startup notifications even if the ID is correct.
TELEGRAM_ADMIN_IDS=

# When true, non-admin users see maintenance responses instead of download actions.
TELEGRAM_MAINTENANCE_MODE=false

# yt-dlp authentication for YouTube and other protected sources.
# Use only one or two of these depending on your setup.

# Option 1: reuse cookies directly from a local browser profile.
# Examples: chrome, edge, firefox, brave
YTDLP_COOKIES_FROM_BROWSER=

# Option 2: point to a Netscape cookies.txt file on disk.
YTDLP_COOKIES_FILE=

# Option 3: pass a base64-encoded cookies.txt payload, useful on hosted platforms.
YTDLP_COOKIES_BASE64=